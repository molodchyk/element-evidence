{
  "name": "element-evidence",
  "version": "1.0.0",
  "description": "Chrome DevTools extension for copying a selected element as one DOM and locator evidence bundle.",
  "type": "module",
  "private": false,
  "license": "GPL-3.0-only",
  "scripts": {
    "test": "node --test",
    "verify:manifest": "node scripts/verify-manifest.mjs",
    "verify:imports": "node scripts/verify-imports.mjs",
    "verify:package": "node scripts/verify-package.mjs",
    "verify": "npm run verify:manifest && npm run verify:imports && npm run verify:package && npm test",
    "store:assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-store-assets.ps1",
    "package": "node scripts/pack-extension.mjs",
    "smoke:sidebar": "node scripts/smoke-sidebar-ui.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/molodchyk/element-evidence.git"
  },
  "bugs": {
    "url": "https://github.com/molodchyk/element-evidence/issues"
  },
  "homepage": "https://github.com/molodchyk/element-evidence"
}
