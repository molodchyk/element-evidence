{
  "manifest_version": 3,
  "name": "Element Evidence: Copy DOM & Locators",
  "short_name": "Element Evidence",
  "description": "Copy a selected DevTools element as one JSON bundle with DOM, locators, styles, and page context.",
  "version": "1.0.0",
  "permissions": [
    "clipboardWrite"
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "devtools_page": "src/app/devtools/devtools.html"
}
